{
  "name": "ai-edits-3d-scene",
  "version": "0.1.0",
  "description": "A real DeepAgentsJS + OpenRouter demo that edits a live Three.js scene from a prompt.",
  "private": false,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qingpengchen2011/ai-edits-3d-scene.git"
  },
  "keywords": [
    "deepagents",
    "openrouter",
    "threejs",
    "langchain",
    "ai-demo"
  ],
  "scripts": {
    "dev": "tsx server/dev.ts",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.server.json && vite build",
    "test": "vitest run",
    "start": "node dist-server/server/dev.js"
  },
  "dependencies": {
    "@langchain/core": "^1.0.6",
    "@langchain/langgraph": "^1.0.3",
    "@langchain/openrouter": "^0.3.0",
